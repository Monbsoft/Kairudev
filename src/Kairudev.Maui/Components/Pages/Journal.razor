@page "/journal"
@using Kairudev.Maui.Services
@using Kairudev.Maui.Auth
@inject JournalApiClient Api
@inject MauiAuthService AuthService
@inject NavigationManager Nav

<div class="d-flex align-items-center justify-content-between mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="PreviousDay" title="Jour précédent" aria-label="Jour précédent">←</button>
    <h2 class="mb-0">📖 @GetJournalTitle()</h2>
    <button class="btn btn-outline-secondary btn-sm" @onclick="NextDay" disabled="@IsToday" title="Jour suivant" aria-label="Jour suivant">→</button>
</div>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (entries is null)
{
    <p>Chargement…</p>
}
else if (entries.Count == 0)
{
    <p class="text-muted">Aucune activité enregistrée ce jour.</p>
}
else
{
    <div class="journal-list">
        @foreach (var entry in entries)
        {
            <div class="journal-entry mb-3 p-3 border rounded">
                <div class="d-flex align-items-start">
                    <div class="entry-time me-3">
                        <strong class="text-primary">@entry.OccurredAt.ToLocalTime().ToString("HH:mm")</strong>
                    </div>
                    <div class="entry-icon me-2">
                        @GetEventIcon(entry.EventType)
                    </div>
                    <div class="flex-grow-1">
                        <div class="entry-label mb-2">
                            <strong>@GetEventLabel(entry)</strong>
                        </div>

                        @if (entry.LinkedTaskTitles.Count > 0)
                        {
                            <ul class="list-unstyled small text-muted ms-2 mb-1">
                                @foreach (var title in entry.LinkedTaskTitles)
                                {
                                    <li>→ @title</li>
                                }
                            </ul>
                        }

                        @if (entry.Comments.Count > 0)
                        {
                            <ul class="list-group list-group-flush mt-2">
                                @foreach (var comment in entry.Comments)
                                {
                                    <li class="list-group-item p-2">
                                        @if (editingCommentId == comment.Id)
                                        {
                                            <textarea class="form-control mb-2"
                                                      @bind="editCommentText"
                                                      @bind:event="oninput"
                                                      rows="2"></textarea>
                                            <button class="btn btn-sm btn-primary me-2" @onclick="() => SaveEditComment(entry.Id, comment.Id)">Enregistrer</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEditComment">Annuler</button>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">@comment.Text</div>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditComment(comment)" title="Modifier">✎</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteComment(entry.Id, comment.Id)" title="Supprimer">✕</button>
                                                </div>
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        }

                        @if (addingCommentForEntryId == entry.Id)
                        {
                            <div class="mt-2">
                                <textarea class="form-control mb-2"
                                          placeholder="Ajouter un commentaire…"
                                          @bind="newCommentText"
                                          @bind:event="oninput"
                                          rows="2"></textarea>
                                <button class="btn btn-sm btn-primary me-2" @onclick="() => SaveAddComment(entry.Id)">Ajouter</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelAddComment">Annuler</button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="() => StartAddComment(entry.Id)">
                                💬 Ajouter un commentaire
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<JournalEntryDto>? entries;
    private string? errorMessage;

    private Guid? addingCommentForEntryId;
    private string newCommentText = string.Empty;

    private Guid? editingCommentId;
    private string editCommentText = string.Empty;

    private DateOnly _displayDate = DateOnly.FromDateTime(DateTime.Today);
    private bool IsToday => _displayDate == DateOnly.FromDateTime(DateTime.Today);

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }
        await LoadEntries();
    }

    private string GetJournalTitle()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        if (_displayDate == today)
            return "Journal d'aujourd'hui";
        if (_displayDate == today.AddDays(-1))
            return "Journal d'hier";
        return $"Journal du {_displayDate.ToString("dddd d MMMM yyyy")}";
    }

    private async Task LoadEntries()
    {
        try
        {
            entries = IsToday
                ? await Api.GetTodayEntriesAsync()
                : await Api.GetEntriesByDateAsync(_displayDate);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement : {ex.Message}";
        }
    }

    // ── Navigation ─────────────────────────────────────────

    private async Task PreviousDay()
    {
        _displayDate = _displayDate.AddDays(-1);
        await LoadEntries();
    }

    private async Task NextDay()
    {
        if (!IsToday)
        {
            _displayDate = _displayDate.AddDays(1);
            await LoadEntries();
        }
    }

    private void StartAddComment(Guid entryId)
    {
        addingCommentForEntryId = entryId;
        newCommentText = string.Empty;
    }

    private async Task SaveAddComment(Guid entryId)
    {
        if (string.IsNullOrWhiteSpace(newCommentText))
            return;

        try
        {
            await Api.AddCommentAsync(entryId, newCommentText);
            addingCommentForEntryId = null;
            newCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout : {ex.Message}";
        }
    }

    private void CancelAddComment()
    {
        addingCommentForEntryId = null;
        newCommentText = string.Empty;
    }

    private void StartEditComment(JournalCommentDto comment)
    {
        editingCommentId = comment.Id;
        editCommentText = comment.Text;
    }

    private async Task SaveEditComment(Guid entryId, Guid commentId)
    {
        if (string.IsNullOrWhiteSpace(editCommentText))
            return;

        try
        {
            await Api.UpdateCommentAsync(entryId, commentId, editCommentText);
            editingCommentId = null;
            editCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la modification : {ex.Message}";
        }
    }

    private void CancelEditComment()
    {
        editingCommentId = null;
        editCommentText = string.Empty;
    }

    private async Task DeleteComment(Guid entryId, Guid commentId)
    {
        try
        {
            await Api.DeleteCommentAsync(entryId, commentId);
            await LoadEntries();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la suppression : {ex.Message}";
        }
    }

    private static string GetEventIcon(string eventType) => eventType switch
    {
        "SprintStarted"     => "🍅",
        "SprintCompleted"   => "✅",
        "SprintInterrupted" => "⏸️",
        "BreakStarted"      => "☕",
        "BreakCompleted"    => "🌿",
        "BreakInterrupted"  => "⚡",
        "TaskStarted"       => "🚀",
        "TaskCompleted"     => "🎉",
        _                   => "📌"
    };

    private static string GetEventLabel(JournalEntryDto entry) => entry.EventType switch
    {
        "SprintStarted"     => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} démarré"    : "Sprint démarré",
        "SprintCompleted"   => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} complété"   : "Sprint complété",
        "SprintInterrupted" => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} interrompu" : "Sprint interrompu",
        "BreakStarted"      => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} démarrée"    : "Pause démarrée",
        "BreakCompleted"    => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} terminée"    : "Pause terminée",
        "BreakInterrupted"  => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} interrompue" : "Pause interrompue",
        "TaskStarted"       => "Tâche démarrée",
        "TaskCompleted"     => "Tâche complétée",
        _                   => entry.EventType
    };
}
