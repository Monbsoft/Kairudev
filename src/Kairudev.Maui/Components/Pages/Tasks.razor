@page "/tasks"
@using Kairudev.Maui.Services
@using Kairudev.Maui.Auth
@using Markdig
@inject TaskApiClient Api
@inject TicketApiClient TicketApi
@inject MauiAuthService AuthService
@inject NavigationManager Nav

<h2>Tâches du jour</h2>

<div class="mb-3">
    <input class="form-control mb-2"
           placeholder="Titre de la tâche…"
           @bind="newTitle"
           @bind:event="oninput"
           @onkeydown="OnKeyDown" />
    <textarea class="form-control mb-2"
              placeholder="Description (optionnelle)…"
              @bind="newDescription"
              @bind:event="oninput"
              rows="2"></textarea>
    <button class="btn btn-primary" @onclick="AddTask" disabled="@string.IsNullOrWhiteSpace(newTitle)">
        Ajouter
    </button>
</div>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (tasks is null)
{
    <p>Chargement…</p>
}
else if (tasks.Count == 0)
{
    <p class="text-muted">Aucune tâche pour l'instant.</p>
}
else
{
    <ul class="list-group">
        @foreach (var task in tasks)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="@(task.Status == "Done" ? "text-decoration-line-through text-muted" : "")">
                            <button class="btn btn-link p-0 text-start fw-bold" @onclick="() => OpenDetail(task)">@task.Title</button>
                            @if (!string.IsNullOrWhiteSpace(task.JiraTicketKey))
                            {
                                <span class="badge bg-primary ms-2">@task.JiraTicketKey</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <small class="text-muted d-block mt-1">@task.Description</small>
                        }
                        @if (linkingTaskId == task.Id)
                        {
                            <div class="d-flex gap-2 mt-1">
                                <input class="form-control form-control-sm"
                                       style="max-width: 150px"
                                       placeholder="PROJ-123"
                                       @bind="linkJiraKeyInput"
                                       @bind:event="oninput" />
                                <button class="btn btn-sm btn-primary" @onclick="() => SaveJiraLink(task.Id)">Lier</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelJiraLink">Annuler</button>
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 align-items-center ms-3">
                        <span class="badge @StatusBadgeClass(task.Status)">@task.Status</span>
                        @if (task.Status != "Done")
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => { OpenDetail(task); StartMarkdownEdit(); }" title="Modifier">&#x270E;</button>
                            <button class="btn btn-sm btn-success" @onclick="() => CompleteTask(task.Id)" title="Compléter">&#x2713;</button>
                        }
                        @if (string.IsNullOrWhiteSpace(task.JiraTicketKey))
                        {
                            <button class="btn btn-sm btn-outline-info" @onclick="() => StartJiraLink(task.Id)" title="Lier Jira">J+</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => UnlinkJira(task.Id)" title="Délier Jira">J-</button>
                        }
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)" title="Supprimer">&#x2715;</button>
                    </div>
                </div>
            </li>
        }
    </ul>
}

@* Modale Bootstrap sans JS *@
<div class="modal @(detailTask != null ? "show d-block" : "")" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @if (detailTask != null && !isEditing)
            {
                <div class="modal-header">
                    <h5 class="modal-title">@detailTask.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    @if (string.IsNullOrWhiteSpace(detailTask.Description))
                    {
                        <p class="text-muted fst-italic">Aucune description.</p>
                    }
                    else
                    {
                        @((MarkupString)RenderMarkdown(detailTask.Description))
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="StartMarkdownEdit">Modifier</button>
                    <button class="btn btn-secondary" @onclick="CloseDetail">Fermer</button>
                </div>
            }
            @if (detailTask != null && isEditing)
            {
                <div class="modal-header">
                    <h5 class="modal-title">Modifier la tâche</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Titre</label>
                        <input class="form-control" @bind="editTitle" @bind:event="oninput" placeholder="Titre…" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <ul class="nav nav-tabs mb-2">
                            <li class="nav-item">
                                <button class="nav-link @(editTab == "edit" ? "active" : "")" @onclick='() => editTab = "edit"'>Éditer</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(editTab == "preview" ? "active" : "")" @onclick='() => editTab = "preview"'>Prévisualiser</button>
                            </li>
                        </ul>
                        @if (editTab == "edit")
                        {
                            <textarea class="form-control font-monospace"
                                      rows="10"
                                      @bind="editDescMd"
                                      @bind:event="oninput"
                                      placeholder="Description en Markdown…"></textarea>
                            <div class="mt-1 small @(editDescMd.Length > DescriptionMaxLength ? "text-danger fw-bold" : "text-muted")">
                                @editDescMd.Length / @DescriptionMaxLength
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-3 bg-light" style="min-height: 200px;">
                                @if (string.IsNullOrWhiteSpace(editDescMd))
                                {
                                    <p class="text-muted fst-italic">Aucun contenu à prévisualiser.</p>
                                }
                                else
                                {
                                    @((MarkupString)RenderMarkdown(editDescMd))
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary"
                            disabled="@(editDescMd.Length > DescriptionMaxLength || string.IsNullOrWhiteSpace(editTitle))"
                            @onclick="SaveMarkdownEdit">Enregistrer</button>
                    <button class="btn btn-secondary" @onclick="() => { isEditing = false; }">Annuler</button>
                </div>
            }
        </div>
    </div>
</div>
@if (detailTask != null)
{
    <div class="modal-backdrop fade show"></div>
}

@code {
    private const int DescriptionMaxLength = 5000;

    private static readonly MarkdownPipeline _pipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private List<TaskDto>? tasks;
    private string newTitle = string.Empty;
    private string newDescription = string.Empty;
    private string? errorMessage;

    private TaskDto? detailTask;
    private bool isEditing;
    private string editTab = "edit";
    private string editTitle = string.Empty;
    private string editDescMd = string.Empty;

    private Guid? linkingTaskId;
    private string linkJiraKeyInput = string.Empty;

    private string RenderMarkdown(string? md) =>
        string.IsNullOrWhiteSpace(md) ? string.Empty : Markdown.ToHtml(md, _pipeline);

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }
        tasks = await Api.GetAllAsync();
    }

    private void OpenDetail(TaskDto task)
    {
        detailTask = task;
        isEditing = false;
        editTab = "edit";
    }

    private void CloseDetail()
    {
        detailTask = null;
        isEditing = false;
    }

    private void StartMarkdownEdit()
    {
        if (detailTask is null) return;
        editTitle = detailTask.Title;
        editDescMd = detailTask.Description ?? string.Empty;
        isEditing = true;
        editTab = "edit";
    }

    private async Task SaveMarkdownEdit()
    {
        if (detailTask is null || editDescMd.Length > DescriptionMaxLength) return;
        errorMessage = null;
        var description = string.IsNullOrWhiteSpace(editDescMd) ? null : editDescMd.Trim();
        var updated = await Api.UpdateAsync(detailTask.Id, editTitle.Trim(), description);
        if (updated is not null)
        {
            var index = tasks!.FindIndex(t => t.Id == detailTask.Id);
            if (index >= 0) tasks[index] = updated;
            detailTask = updated;
            isEditing = false;
        }
        else
        {
            errorMessage = "Erreur lors de la modification.";
        }
    }

    private async Task AddTask()
    {
        errorMessage = null;
        var description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim();
        var added = await Api.AddAsync(newTitle.Trim(), description);
        if (added is not null)
        {
            tasks ??= [];
            tasks.Add(added);
            newTitle = string.Empty;
            newDescription = string.Empty;
        }
        else
        {
            errorMessage = "Erreur lors de l'ajout de la tâche.";
        }
    }

    private async Task CompleteTask(Guid id)
    {
        errorMessage = null;
        if (await Api.CompleteAsync(id))
            tasks = await Api.GetAllAsync();
        else
            errorMessage = "Erreur lors de la complétion.";
    }

    private async Task DeleteTask(Guid id)
    {
        errorMessage = null;
        if (await Api.DeleteAsync(id))
        {
            tasks!.RemoveAll(t => t.Id == id);
            if (detailTask?.Id == id) CloseDetail();
        }
        else
        {
            errorMessage = "Erreur lors de la suppression.";
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newTitle))
            await AddTask();
    }

    private void StartJiraLink(Guid taskId)
    {
        linkingTaskId = taskId;
        linkJiraKeyInput = string.Empty;
    }

    private async Task SaveJiraLink(Guid taskId)
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(linkJiraKeyInput)) return;

        if (await TicketApi.LinkAsync(taskId, linkJiraKeyInput.Trim()))
        {
            tasks = await Api.GetAllAsync();
            CancelJiraLink();
        }
        else
        {
            errorMessage = "Erreur lors de la liaison Jira. Vérifiez la clé saisie.";
        }
    }

    private async Task UnlinkJira(Guid taskId)
    {
        errorMessage = null;
        if (await TicketApi.UnlinkAsync(taskId))
            tasks = await Api.GetAllAsync();
        else
            errorMessage = "Erreur lors de la suppression du lien Jira.";
    }

    private void CancelJiraLink()
    {
        linkingTaskId = null;
        linkJiraKeyInput = string.Empty;
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Done" => "bg-success",
        "InProgress" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
