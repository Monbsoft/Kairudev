@page "/tasks/{Id:guid}/edit"
@attribute [Authorize]
@using Kairudev.Web.Services
@inject TaskApiClient Api
@inject NavigationManager Nav
@inject MarkdownService MarkdownSvc

@if (notFound)
{
    <div class="alert alert-warning">Tâche introuvable.</div>
    <button class="btn btn-secondary" @onclick="GoBack">Retour</button>
}
else if (task is null)
{
    <p>Chargement…</p>
}
else
{
    <h2>Modifier la tâche</h2>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mb-3">
        <label class="form-label fw-bold">Titre</label>
        <input class="form-control" @bind="editTitle" @bind:event="oninput" placeholder="Titre…" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Tags</label>
        <div class="d-flex flex-wrap gap-1 mb-1">
            @foreach (var tag in editTags)
            {
                <span class="badge @TagColorClass(tag)">
                    @tag
                    <button type="button" class="btn-close btn-close-white ms-1" style="font-size:0.6em;"
                            @onclick="() => RemoveEditTag(tag)" aria-label="Retirer"></button>
                </span>
            }
        </div>
        <div class="input-group" style="max-width: 320px;">
            <input class="form-control form-control-sm"
                   placeholder="@(editTags.Count >= MaxTags ? "Maximum 5 tags" : "Ajouter un tag… (Entrée)")"
                   disabled="@(editTags.Count >= MaxTags)"
                   @bind="editTagInput"
                   @bind:event="oninput"
                   @onkeydown="OnEditTagKeyDown" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Description</label>
        <ul class="nav nav-tabs mb-2">
            <li class="nav-item">
                <button class="nav-link @(editTab == "edit" ? "active" : "")" @onclick='() => editTab = "edit"'>Éditer</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(editTab == "preview" ? "active" : "")" @onclick='() => editTab = "preview"'>Prévisualiser</button>
            </li>
        </ul>
        @if (editTab == "edit")
        {
            <textarea class="form-control font-monospace"
                      rows="12"
                      @bind="editDescMd"
                      @bind:event="oninput"
                      placeholder="Description en Markdown…"></textarea>
            <div class="mt-1 small @(editDescMd.Length > DescriptionMaxLength ? "text-danger fw-bold" : "text-muted")">
                @editDescMd.Length / @DescriptionMaxLength
            </div>
        }
        else
        {
            <div class="border rounded p-3 bg-body-tertiary" style="min-height: 200px;">
                @if (string.IsNullOrWhiteSpace(editDescMd))
                {
                    <p class="text-muted fst-italic">Aucun contenu à prévisualiser.</p>
                }
                else
                {
                    @((MarkupString)MarkdownSvc.Render(editDescMd))
                }
            </div>
        }
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary"
                disabled="@(editDescMd.Length > DescriptionMaxLength || string.IsNullOrWhiteSpace(editTitle))"
                @onclick="SaveEdit">Enregistrer</button>
        <button class="btn btn-secondary" @onclick="GoBack">Annuler</button>
    </div>
}

@code {
    private const int MaxTags = 5;

    private static readonly string[] TagPalette =
    [
        "bg-primary",
        "bg-success",
        "bg-danger",
        "bg-warning text-dark",
        "bg-info text-dark",
        "bg-secondary",
        "text-bg-purple",
        "text-bg-orange",
        "text-bg-teal",
        "text-bg-pink"
    ];

    private static string TagColorClass(string tag)
    {
        var hash = Math.Abs(tag.ToLowerInvariant().GetHashCode());
        return TagPalette[hash % TagPalette.Length];
    }

    [Parameter] public Guid Id { get; set; }

    private const int DescriptionMaxLength = 5000;

    private TaskDto? task;
    private bool notFound;
    private string? errorMessage;

    private string editTitle = string.Empty;
    private string editDescMd = string.Empty;
    private string editTab = "edit";
    private string editTagInput = string.Empty;
    private List<string> editTags = [];

    protected override async Task OnInitializedAsync()
    {
        task = await Api.GetByIdAsync(Id);
        notFound = task is null;
        if (task is not null && task.Status == "Done")
        {
            Nav.NavigateTo($"/tasks/{Id}");
            return;
        }
        if (task is not null)
        {
            editTitle = task.Title;
            editDescMd = task.Description ?? string.Empty;
            editTags = task.Tags is not null ? [.. task.Tags] : [];
        }
    }

    private void AddEditTagFromInput()
    {
        var trimmed = editTagInput.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || editTags.Count >= MaxTags) return;
        if (editTags.Any(t => string.Equals(t, trimmed, StringComparison.OrdinalIgnoreCase))) return;
        if (trimmed.Length > 30) return;
        editTags.Add(trimmed);
        editTagInput = string.Empty;
    }

    private void RemoveEditTag(string tag) => editTags.Remove(tag);

    private void OnEditTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddEditTagFromInput();
    }

    private async Task SaveEdit()
    {
        if (task is null || editDescMd.Length > DescriptionMaxLength) return;
        errorMessage = null;
        var description = string.IsNullOrWhiteSpace(editDescMd) ? null : editDescMd.Trim();
        var updated = await Api.UpdateAsync(Id, editTitle.Trim(), description, editTags.Count > 0 ? editTags : []);
        if (updated is not null)
        {
            Nav.NavigateTo("/tasks");
        }
        else
        {
            errorMessage = "Erreur lors de la modification.";
        }
    }

    private void GoBack() => Nav.NavigateTo("/tasks");
}

