@page "/journal"
@attribute [Authorize]
@using Kairudev.Web.Services
@inject JournalApiClient Api

<div class="notebook">

    <div class="notebook-header">
        <button class="nb-nav-btn" @onclick="PreviousDay" title="Jour précédent" aria-label="Jour précédent">←</button>
        <div class="notebook-title">
            <span class="notebook-day">@GetDayName()</span>
            <span class="notebook-date">@GetDateFull()</span>
        </div>
        <button class="nb-nav-btn" @onclick="NextDay" disabled="@IsToday" title="Jour suivant" aria-label="Jour suivant">→</button>
    </div>

    <div class="notebook-body">

        @if (errorMessage is not null)
        {
            <div class="alert alert-danger mx-3 mt-3">@errorMessage</div>
        }

        @if (entries is null)
        {
            <p class="text-muted px-4 pt-3 fst-italic">Chargement…</p>
        }
        else if (entries.Count == 0)
        {
            <div class="notebook-empty">
                <div class="notebook-empty-icon">📓</div>
                <p class="text-muted fst-italic mb-1">Aucune activité enregistrée ce jour.</p>
                @if (IsToday)
                {
                    <p class="text-muted small">Démarrez un sprint Pomodoro pour voir apparaître vos entrées ici.</p>
                }
            </div>
        }
        else
        {
            <div class="notebook-timeline">
                @foreach (var entry in entries)
                {
                    <div class="nb-entry nb-@GetEntryVariant(entry.EventType)">
                        <div class="nb-time">@entry.OccurredAt.ToLocalTime().ToString("HH:mm")</div>
                        <div class="nb-dot-col">
                            <div class="nb-dot"></div>
                            <div class="nb-line"></div>
                        </div>
                        <div class="nb-content">
                            <div class="nb-event">
                                <span class="nb-icon">@GetEventIcon(entry.EventType)</span>
                                <span class="nb-label">@GetEventLabel(entry)</span>
                            </div>

                            @if (entry.LinkedTaskTitles.Count > 0)
                            {
                                <div class="nb-tasks">
                                    <span class="nb-tasks-header">Tâches travaillées</span>
                                    <ul class="nb-tasks-list">
                                        @foreach (var title in entry.LinkedTaskTitles)
                                        {
                                            <li>@title</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @foreach (var comment in entry.Comments)
                            {
                                <div class="nb-comment">
                                    @if (editingCommentId == comment.Id)
                                    {
                                        <textarea class="form-control form-control-sm mb-1"
                                                  @bind="editCommentText"
                                                  @bind:event="oninput"
                                                  rows="2"></textarea>
                                        <button class="btn btn-sm btn-primary me-1" @onclick="() => SaveEditComment(entry.Id, comment.Id)">✓ Enregistrer</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditComment">Annuler</button>
                                    }
                                    else
                                    {
                                        <div class="nb-comment-body">
                                            <span class="nb-comment-text">✏️ @comment.Text</span>
                                            <span class="nb-comment-actions">
                                                <button class="btn-icon" @onclick="() => StartEditComment(comment)" title="Modifier">✎</button>
                                                <button class="btn-icon btn-icon-danger" @onclick="() => DeleteComment(entry.Id, comment.Id)" title="Supprimer">✕</button>
                                            </span>
                                        </div>
                                    }
                                </div>
                            }

                            @if (addingCommentForEntryId == entry.Id)
                            {
                                <div class="nb-add-comment mt-2">
                                    <textarea class="form-control form-control-sm mb-1"
                                              placeholder="Votre note…"
                                              @bind="newCommentText"
                                              @bind:event="oninput"
                                              rows="2"></textarea>
                                    <button class="btn btn-sm btn-primary me-1" @onclick="() => SaveAddComment(entry.Id)">Ajouter</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelAddComment">Annuler</button>
                                </div>
                            }
                            else
                            {
                                <button class="nb-add-btn" @onclick="() => StartAddComment(entry.Id)">+ note</button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    /* ── Variables — light (défaut) ──────────────────────── */
    .notebook {
        --nb-body-bg:            #fafaf7;
        --nb-body-border:        #e4e0d8;
        --nb-dot-default-bg:     #fafaf7;
        --nb-dot-default-border: #c8c4bc;
        --nb-line-color:         #e8e4da;
        --nb-time-color:         #a09ea8;
        --nb-label-color:        #2c2c3a;
        --nb-tasks-label-color:  #9896a8;
        --nb-tasks-item-color:   #3a3848;
        --nb-comment-bg:         #f0ede6;
        --nb-comment-border:     #d4c89a;
        --nb-comment-text-color: #3c3a4a;
        --nb-add-btn-border:     #ccc8be;
        --nb-add-btn-color:      #b0aeba;
        --nb-btn-icon-color:     #888888;
        --nb-sprint-dot-bg:      #e8f0fe;
        --nb-break-dot-bg:       #e8f5ee;
        --nb-task-dot-bg:        #f0ebfa;
        --nb-warn-dot-bg:        #fff3e8;
        max-width: 700px;
        margin: 0 auto;
    }

    /* ── Variables — dark ────────────────────────────────── */
    [data-bs-theme="dark"] .notebook {
        --nb-body-bg:            #13131f;
        --nb-body-border:        #252538;
        --nb-dot-default-bg:     #13131f;
        --nb-dot-default-border: #3a3a5c;
        --nb-line-color:         #252538;
        --nb-time-color:         #6272a4;
        --nb-label-color:        #ccd6f6;
        --nb-tasks-label-color:  #6272a4;
        --nb-tasks-item-color:   #8892b0;
        --nb-comment-bg:         #1c1c2e;
        --nb-comment-border:     #3a3a5c;
        --nb-comment-text-color: #8892b0;
        --nb-add-btn-border:     #3a3a5c;
        --nb-add-btn-color:      #6272a4;
        --nb-btn-icon-color:     #6272a4;
        --nb-sprint-dot-bg:      #0d1b3e;
        --nb-break-dot-bg:       #0d2818;
        --nb-task-dot-bg:        #1e0d3e;
        --nb-warn-dot-bg:        #3e1e0d;
    }

    /* ── En-tête (déjà sombre, invariant) ───────────────── */
    .notebook-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 8px 8px 0 0;
        padding: 1.25rem 1.25rem;
        display: grid;
        grid-template-columns: 40px 1fr 40px;
        align-items: center;
        gap: 0.5rem;
    }

    .notebook-title {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    /* ── Boutons navigation ──────────────────────────────── */
    .nb-nav-btn {
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 4px;
        color: #ccd6f6;
        font-size: 1rem;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.15s;
        padding: 0;
        justify-self: center;
    }

    .nb-nav-btn:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.4);
    }

    .nb-nav-btn:disabled {
        opacity: 0.3;
        cursor: default;
    }

    .notebook-day {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #8892b0;
        font-weight: 700;
    }

    .notebook-date {
        font-size: 1.3rem;
        font-weight: 700;
        color: #e6f1ff;
        line-height: 1.2;
    }

    .notebook-subtitle {
        font-size: 0.75rem;
        color: #8892b0;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        align-self: flex-end;
    }

    /* ── Corps ───────────────────────────────────────────── */
    .notebook-body {
        background: var(--nb-body-bg);
        border: 1px solid var(--nb-body-border);
        border-top: none;
        border-radius: 0 0 8px 8px;
        min-height: 120px;
    }

    .notebook-empty {
        padding: 3rem 2rem;
        text-align: center;
    }

    .notebook-empty-icon {
        font-size: 2.5rem;
        margin-bottom: 0.75rem;
        opacity: 0.4;
    }

    /* ── Timeline ────────────────────────────────────────── */
    .notebook-timeline {
        padding: 1rem 1.25rem 1rem 0.75rem;
    }

    .nb-entry {
        display: grid;
        grid-template-columns: 48px 20px 1fr;
        gap: 0 0.5rem;
        min-height: 40px;
    }

    /* Colonne heure */
    .nb-time {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--nb-time-color);
        font-variant-numeric: tabular-nums;
        text-align: right;
        padding-top: 2px;
        letter-spacing: 0.02em;
    }

    /* Colonne dot + ligne */
    .nb-dot-col {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .nb-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid var(--nb-dot-default-border);
        background: var(--nb-dot-default-bg);
        flex-shrink: 0;
        margin-top: 4px;
    }

    .nb-line {
        width: 2px;
        flex-grow: 1;
        background: var(--nb-line-color);
        margin-top: 3px;
        min-height: 16px;
    }

    .nb-entry:last-child .nb-line {
        display: none;
    }

    /* Variantes de couleur des dots */
    .nb-sprint .nb-dot { border-color: #0d6efd; background: var(--nb-sprint-dot-bg); }
    .nb-break  .nb-dot { border-color: #198754; background: var(--nb-break-dot-bg);  }
    .nb-task   .nb-dot { border-color: #6f42c1; background: var(--nb-task-dot-bg);   }
    .nb-warn   .nb-dot { border-color: #fd7e14; background: var(--nb-warn-dot-bg);   }

    /* ── Contenu d'une entrée ────────────────────────────── */
    .nb-content {
        padding-bottom: 1rem;
    }

    .nb-event {
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        margin-bottom: 0.2rem;
    }

    .nb-icon {
        font-size: 0.95rem;
        line-height: 1;
    }

    .nb-label {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--nb-label-color);
    }

    /* ── Tâches travaillées ──────────────────────────────── */
    .nb-tasks {
        margin: 0.3rem 0 0.2rem 1.4rem;
    }

    .nb-tasks-header {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--nb-tasks-label-color);
        font-weight: 700;
    }

    .nb-tasks-list {
        margin: 0.2rem 0 0 0;
        padding: 0;
        list-style: none;
    }

    .nb-tasks-list li {
        font-size: 0.83rem;
        color: var(--nb-tasks-item-color);
        padding: 0.1rem 0;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .nb-tasks-list li::before {
        content: '→';
        color: #0d6efd;
        font-weight: 700;
        font-size: 0.75rem;
    }

    /* ── Commentaires ────────────────────────────────────── */
    .nb-comment {
        margin: 0.3rem 0 0 1.4rem;
    }

    .nb-comment-body {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
        background: var(--nb-comment-bg);
        border-left: 3px solid var(--nb-comment-border);
        padding: 0.3rem 0.5rem;
        border-radius: 0 4px 4px 0;
        font-size: 0.82rem;
    }

    .nb-comment-text {
        flex-grow: 1;
        color: var(--nb-comment-text-color);
    }

    .nb-comment-actions {
        display: flex;
        gap: 0.2rem;
        opacity: 0;
        transition: opacity 0.15s;
        flex-shrink: 0;
    }

    .nb-comment-body:hover .nb-comment-actions,
    .nb-comment-body:focus-within .nb-comment-actions {
        opacity: 1;
    }

    .btn-icon {
        background: none;
        border: none;
        padding: 0 0.2rem;
        font-size: 0.78rem;
        cursor: pointer;
        color: var(--nb-btn-icon-color);
        line-height: 1;
    }

    .btn-icon:hover         { color: #0d6efd; }
    .btn-icon-danger:hover  { color: #dc3545; }

    /* ── Bouton + note ───────────────────────────────────── */
    .nb-add-btn {
        background: none;
        border: 1px dashed var(--nb-add-btn-border);
        border-radius: 4px;
        padding: 0.12rem 0.5rem;
        font-size: 0.72rem;
        color: var(--nb-add-btn-color);
        cursor: pointer;
        margin-left: 1.4rem;
        margin-top: 0.25rem;
        display: inline-block;
        transition: all 0.15s;
    }

    .nb-add-btn:hover {
        border-color: #0d6efd;
        color: #0d6efd;
        background: var(--nb-sprint-dot-bg);
    }
</style>

@code {
    private List<JournalEntryDto>? entries;
    private string? errorMessage;

    private Guid? addingCommentForEntryId;
    private string newCommentText = string.Empty;

    private Guid? editingCommentId;
    private string editCommentText = string.Empty;

    private DateOnly _displayDate = DateOnly.FromDateTime(DateTime.Today);
    private bool IsToday => _displayDate == DateOnly.FromDateTime(DateTime.Today);

    private static readonly System.Globalization.CultureInfo Fr = new("fr-FR");

    protected override async Task OnInitializedAsync() =>
        await LoadEntries();

    private async Task LoadEntries()
    {
        try
        {
            entries = IsToday
                ? await Api.GetTodayEntriesAsync()
                : await Api.GetEntriesByDateAsync(_displayDate);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement : {ex.Message}";
        }
    }

    // ── Navigation ────────────────────────────────────────

    private async Task PreviousDay()
    {
        _displayDate = _displayDate.AddDays(-1);
        await LoadEntries();
    }

    private async Task NextDay()
    {
        if (!IsToday)
        {
            _displayDate = _displayDate.AddDays(1);
            await LoadEntries();
        }
    }

    // ── Helpers date ──────────────────────────────────────

    private string GetDayName() =>
        _displayDate.ToString("dddd", Fr).ToUpperInvariant();

    private string GetDateFull() =>
        _displayDate.ToString("d MMMM yyyy", Fr);

    // ── Helpers entrée ────────────────────────────────────

    private static string GetEntryVariant(string eventType) => eventType switch
    {
        "SprintStarted" or "SprintCompleted"    => "sprint",
        "SprintInterrupted"                     => "warn",
        "BreakStarted"  or "BreakCompleted"     => "break",
        "BreakInterrupted"                      => "warn",
        "TaskStarted"   or "TaskCompleted"      => "task",
        _                                       => "sprint"
    };

    private static string GetEventIcon(string eventType) => eventType switch
    {
        "SprintStarted"     => "🍅",
        "SprintCompleted"   => "✅",
        "SprintInterrupted" => "⏸️",
        "BreakStarted"      => "☕",
        "BreakCompleted"    => "🌿",
        "BreakInterrupted"  => "⚡",
        "TaskStarted"       => "🚀",
        "TaskCompleted"     => "🎉",
        _                   => "📌"
    };

    private static string GetEventLabel(JournalEntryDto entry) => entry.EventType switch
    {
        "SprintStarted"     => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} démarré"    : "Sprint démarré",
        "SprintCompleted"   => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} complété"   : "Sprint complété",
        "SprintInterrupted" => entry.Sequence.HasValue ? $"Sprint #{entry.Sequence} interrompu" : "Sprint interrompu",
        "BreakStarted"      => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} démarrée"    : "Pause démarrée",
        "BreakCompleted"    => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} terminée"    : "Pause terminée",
        "BreakInterrupted"  => entry.Sequence.HasValue ? $"Pause #{entry.Sequence} interrompue" : "Pause interrompue",
        "TaskStarted"       => "Tâche démarrée",
        "TaskCompleted"     => "Tâche complétée",
        _                   => entry.EventType
    };

    // ── Actions commentaires ──────────────────────────────

    private void StartAddComment(Guid entryId)
    {
        addingCommentForEntryId = entryId;
        newCommentText = string.Empty;
    }

    private async Task SaveAddComment(Guid entryId)
    {
        if (string.IsNullOrWhiteSpace(newCommentText)) return;
        try
        {
            await Api.AddCommentAsync(entryId, newCommentText);
            addingCommentForEntryId = null;
            newCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de l'ajout : {ex.Message}"; }
    }

    private void CancelAddComment()
    {
        addingCommentForEntryId = null;
        newCommentText = string.Empty;
    }

    private void StartEditComment(JournalCommentDto comment)
    {
        editingCommentId = comment.Id;
        editCommentText = comment.Text;
    }

    private async Task SaveEditComment(Guid entryId, Guid commentId)
    {
        if (string.IsNullOrWhiteSpace(editCommentText)) return;
        try
        {
            await Api.UpdateCommentAsync(entryId, commentId, editCommentText);
            editingCommentId = null;
            editCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de la modification : {ex.Message}"; }
    }

    private void CancelEditComment()
    {
        editingCommentId = null;
        editCommentText = string.Empty;
    }

    private async Task DeleteComment(Guid entryId, Guid commentId)
    {
        try
        {
            await Api.DeleteCommentAsync(entryId, commentId);
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de la suppression : {ex.Message}"; }
    }
}
