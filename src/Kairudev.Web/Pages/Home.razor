@page "/"
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager Nav
@inject IConfiguration Configuration

<PageTitle>Kairudev — Votre espace de travail</PageTitle>

<div class="landing">
    <section class="landing-hero">
        <div class="landing-hero-content">
            <div class="landing-logo">K</div>
            <h1 class="landing-title">Kairudev</h1>
            <p class="landing-tagline">L'espace de travail du developpeur focus</p>
            <p class="landing-desc">
                Centralisez vos taches, vos sessions de travail, votre journal d'activite
                et vos tickets — en un seul endroit.
            </p>
            <a href="@_githubLoginUrl" class="btn btn-github btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="me-2" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                Se connecter avec GitHub
            </a>
        </div>
    </section>

    <section class="landing-features">
        <div class="container">
            <div class="row g-4 justify-content-center">
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon">&#9745;</div>
                        <h3 class="feature-title">Taches</h3>
                        <p class="feature-desc">Micro-taches quotidiennes avec statuts, descriptions et lien direct vers vos tickets Jira.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon">&#127813;</div>
                        <h3 class="feature-title">Pomodoro</h3>
                        <p class="feature-desc">Sprints et pauses chronometres, suggestions intelligentes et lien avec vos taches en cours.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon">&#128214;</div>
                        <h3 class="feature-title">Journal</h3>
                        <p class="feature-desc">Timeline d'activite generee automatiquement. Annotez, naviguez dans l'historique.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon">&#127915;</div>
                        <h3 class="feature-title">Tickets</h3>
                        <p class="feature-desc">Integration Jira Cloud. Consultez vos tickets assignes et liez-les a vos taches.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private string _githubLoginUrl = "#";

    protected override void OnInitialized()
    {
        var apiBase = Configuration["ApiBaseUrl"] ?? string.Empty;
        _githubLoginUrl = $"{apiBase}/api/auth/github";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (await AuthService.IsAuthenticatedAsync())
            Nav.NavigateTo("/dashboard", forceLoad: false);
    }
}
