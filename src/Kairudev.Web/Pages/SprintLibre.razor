@page "/pomodoro/libre"
@attribute [Authorize]
@using Kairudev.Web.Services
@inject SprintApiClient SprintApi
@inject TaskApiClient TaskApi
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="mb-3">
    <a href="/pomodoro" class="btn btn-sm btn-outline-secondary">&larr; Retour</a>
</div>

<h2>Sprint libre</h2>

@if (!_loaded)
{
    <p>Chargement…</p>
}
else
{
    <div class="d-flex flex-column align-items-center gap-3">

        <!-- Configuration (visible seulement avant démarrage) -->
        @if (!_running)
        {
            <div style="width:100%;max-width:480px">
                <div class="mb-3">
                    <label class="form-label">Nom du sprint</label>
                    <input class="form-control"
                           placeholder="Sprint #@(_todaySprints.Count + 1)"
                           @bind="_sprintName"
                           @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tâche liée (optionnel)</label>
                    <select class="form-select" @bind="_selectedTaskId">
                        <option value="">— Aucune tâche —</option>
                        @foreach (var task in _availableTasks)
                        {
                            <option value="@task.Id">@task.Title</option>
                        }
                    </select>
                </div>
            </div>
        }

        <!-- Chronomètre count-up -->
        <div class="display-1 font-monospace" style="letter-spacing: 0.05em; color: @(_running ? "#0d6efd" : "#6c757d")">
            @TimeDisplay
        </div>

        @if (_running)
        {
            <div class="text-muted">
                @(_sprintName.Trim() is { Length: > 0 } name ? name : $"Sprint #{_todaySprints.Count + 1}") en cours
            </div>
        }

        <!-- Boutons de contrôle -->
        <div class="d-flex gap-2">
            @if (!_running)
            {
                <button class="btn btn-primary btn-lg" @onclick="StartSprint">
                    &#9654; Démarrer
                </button>
            }
            else
            {
                <button class="btn btn-success btn-lg" @onclick="FinishSprint">
                    &#10003; Terminer
                </button>
                <button class="btn btn-outline-warning btn-lg" @onclick="InterruptSprint">
                    &#9209; Interrompre
                </button>
            }
        </div>

        @if (_lastRecorded is not null)
        {
            var durationSpan = TimeSpan.FromSeconds(_lastRecorded.DurationSeconds);
            var outcomeLabel = _lastRecorded.Outcome == "Completed" ? "Terminé" : "Interrompu";
            <div class="alert alert-success text-center" style="max-width:360px">
                Sprint enregistré — @_lastRecorded.Name —
                @durationSpan.ToString(@"hh\:mm\:ss") — @outcomeLabel
            </div>
        }

        @if (_errorMessage is not null)
        {
            <div class="alert alert-danger" style="max-width:480px">@_errorMessage</div>
        }

        <!-- Historique du jour -->
        @if (_todaySprints.Count > 0)
        {
            <div style="width:100%;max-width:640px" class="mt-3">
                <h5>Sprints du jour (@_todaySprints.Count)</h5>
                <ul class="list-group">
                    @foreach (var sprint in _todaySprints)
                    {
                        var dur = TimeSpan.FromSeconds(sprint.DurationSeconds);
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@sprint.Name</strong>
                                @if (sprint.LinkedTaskId.HasValue)
                                {
                                    var task = _availableTasks.FirstOrDefault(t => t.Id == sprint.LinkedTaskId);
                                    @if (task is not null)
                                    {
                                        <span class="ms-2 text-muted small">&#128279; @task.Title</span>
                                    }
                                }
                            </div>
                            <span class="d-flex align-items-center gap-2">
                                <span class="font-monospace small">@dur.ToString(@"hh\:mm\:ss")</span>
                                <span class="badge @(sprint.Outcome == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                    @(sprint.Outcome == "Completed" ? "Terminé" : "Interrompu")
                                </span>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

    </div>
}

@code {
    // ── État ──────────────────────────────────────────────────────────────
    private bool _loaded;
    private bool _running;
    private string _sprintName = string.Empty;
    private string _selectedTaskId = string.Empty;
    private DateTimeOffset _startedAt;
    private int _elapsedSeconds;
    private List<SprintSessionDto> _todaySprints = [];
    private List<TaskDto> _availableTasks = [];
    private SprintSessionDto? _lastRecorded;
    private string? _errorMessage;
    private CancellationTokenSource? _timerCts;

    // ── Computed ──────────────────────────────────────────────────────────
    private string TimeDisplay =>
        $"{_elapsedSeconds / 3600:D2}:{_elapsedSeconds % 3600 / 60:D2}:{_elapsedSeconds % 60:D2}";

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _todaySprints = await SprintApi.GetTodaySprintsAsync();
        _availableTasks = (await TaskApi.GetAllAsync())
            .Where(t => t.Status != "Done")
            .ToList();
        _loaded = true;
    }

    public async ValueTask DisposeAsync()
    {
        await StopTimer();
    }

    // ── Actions ───────────────────────────────────────────────────────────
    private async Task StartSprint()
    {
        _errorMessage = null;
        _lastRecorded = null;
        _startedAt = DateTimeOffset.UtcNow;
        _elapsedSeconds = 0;
        _running = true;
        await StartTimerLoop();
    }

    private async Task FinishSprint()
    {
        await StopTimer();
        var endedAt = DateTimeOffset.UtcNow;
        await RecordSprint(endedAt, "Completed");
    }

    private async Task InterruptSprint()
    {
        await StopTimer();
        var endedAt = DateTimeOffset.UtcNow;
        await RecordSprint(endedAt, "Interrupted");
    }

    private async Task RecordSprint(DateTimeOffset endedAt, string outcome)
    {
        _running = false;
        _errorMessage = null;

        var sprintNumber = _todaySprints.Count + 1;
        var name = _sprintName.Trim() is { Length: > 0 } n ? n : null;

        Guid? linkedTaskId = Guid.TryParse(_selectedTaskId, out var taskGuid) ? taskGuid : null;

        var request = new RecordSprintRequest(
            name,
            _startedAt,
            endedAt,
            outcome,
            linkedTaskId,
            sprintNumber);

        var recorded = await SprintApi.RecordSprintAsync(request);
        if (recorded is null)
        {
            _errorMessage = "Impossible d'enregistrer le sprint.";
            return;
        }

        _lastRecorded = recorded;
        _sprintName = string.Empty;
        _selectedTaskId = string.Empty;
        _elapsedSeconds = 0;

        // Refresh today's history
        _todaySprints = await SprintApi.GetTodaySprintsAsync();

        // Refresh available tasks in case statuses changed
        _availableTasks = (await TaskApi.GetAllAsync())
            .Where(t => t.Status != "Done")
            .ToList();
    }

    // ── Timer internals ───────────────────────────────────────────────────
    private async Task StartTimerLoop()
    {
        await StopTimer();
        _timerCts = new CancellationTokenSource();
        var token = _timerCts.Token;

        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            try
            {
                while (await timer.WaitForNextTickAsync(token))
                {
                    _elapsedSeconds++;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private async Task StopTimer()
    {
        if (_timerCts is not null)
        {
            await _timerCts.CancelAsync();
            _timerCts.Dispose();
            _timerCts = null;
        }
    }
}
