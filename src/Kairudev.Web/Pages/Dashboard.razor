@page "/dashboard"
@attribute [Authorize]
@inject AuthService AuthService
@inject TaskApiClient Tasks
@inject PomodoroApiClient Pomodoro
@inject JournalApiClient Journal
@inject NavigationManager Nav

<PageTitle>Tableau de bord — Kairudev</PageTitle>

<div class="dashboard-page">
    @if (!_loaded)
    {
        <div class="d-flex justify-content-center align-items-center" style="height:60vh">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    }
    else
    {
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-greeting">Bonjour, @_userName &#128075;</h1>
                <p class="dashboard-date">@DateTime.Now.ToString("dddd d MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</p>
            </div>
        </div>

        <!-- Stats -->
        <div class="dashboard-stats">
            <div class="stat-card stat-tasks-pending" @onclick='() => Nav.NavigateTo("/tasks")'>
                <div class="stat-icon">&#9745;</div>
                <div class="stat-body">
                    <div class="stat-value">@_tasksPending</div>
                    <div class="stat-label">Taches en cours</div>
                </div>
            </div>
            <div class="stat-card stat-tasks-done" @onclick='() => Nav.NavigateTo("/tasks")'>
                <div class="stat-icon">&#10003;</div>
                <div class="stat-body">
                    <div class="stat-value">@_tasksDone</div>
                    <div class="stat-label">Taches terminees</div>
                </div>
            </div>
            <div class="stat-card stat-pomodoro @(_currentSession is not null ? "stat-active" : "")" @onclick='() => Nav.NavigateTo("/pomodoro")'>
                <div class="stat-icon">&#127813;</div>
                <div class="stat-body">
                    @if (_currentSession is not null)
                    {
                        <div class="stat-value stat-badge-active">En cours</div>
                        <div class="stat-label">@_currentSession.SessionType</div>
                    }
                    else
                    {
                        <div class="stat-value">—</div>
                        <div class="stat-label">Aucun sprint actif</div>
                    }
                </div>
            </div>
            <div class="stat-card stat-journal" @onclick='() => Nav.NavigateTo("/journal")'>
                <div class="stat-icon">&#128214;</div>
                <div class="stat-body">
                    <div class="stat-value">@_journalEntries</div>
                    <div class="stat-label">Entrees aujourd'hui</div>
                </div>
            </div>
        </div>

        <!-- Acces rapides -->
        <h2 class="dashboard-section-title">Acces rapides</h2>
        <div class="dashboard-quicklinks">
            <a href="/tasks" class="quicklink-card">
                <span class="quicklink-icon">&#9745;</span>
                <span class="quicklink-label">Mes taches</span>
            </a>
            <a href="/pomodoro" class="quicklink-card">
                <span class="quicklink-icon">&#127813;</span>
                <span class="quicklink-label">Pomodoro</span>
            </a>
            <a href="/journal" class="quicklink-card">
                <span class="quicklink-icon">&#128214;</span>
                <span class="quicklink-label">Journal</span>
            </a>
            <a href="/tickets" class="quicklink-card">
                <span class="quicklink-icon">&#127915;</span>
                <span class="quicklink-label">Tickets</span>
            </a>
            <a href="/settings" class="quicklink-card">
                <span class="quicklink-icon">&#9881;</span>
                <span class="quicklink-label">Parametres</span>
            </a>
        </div>
    }
</div>

@code {
    private string _userName = "dev";
    private int _tasksPending;
    private int _tasksDone;
    private int _journalEntries;
    private PomodoroSessionDto? _currentSession;
    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var user = await AuthService.GetCurrentUserAsync();
        _userName = user.FindFirst("name")?.Value
            ?? user.FindFirst("login")?.Value
            ?? "dev";

        var tasks = await Tasks.GetAllAsync();
        _tasksPending = tasks.Count(t => t.Status != "Done");
        _tasksDone = tasks.Count(t => t.Status == "Done");

        var entries = await Journal.GetTodayEntriesAsync();
        _journalEntries = entries.Count;

        _currentSession = await Pomodoro.GetCurrentSessionAsync();

        _loaded = true;
        StateHasChanged();
    }
}
