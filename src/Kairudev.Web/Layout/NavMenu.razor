@using Kairudev.Web.Auth
@inject AuthService AuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="top-row navbar navbar-dark">
    <div class="container-fluid justify-content-center">
        <span class="navbar-brand-icon">K</span>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column align-items-center">
        <div class="nav-item">
            <NavLink class="nav-link nav-icon" href="dashboard" title="Tableau de bord" Match="NavLinkMatch.Prefix">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link nav-icon" href="tasks" title="Taches" Match="NavLinkMatch.Prefix">
                <span aria-hidden="true">&#9745;</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link nav-icon" href="pomodoro" title="Pomodoro" Match="NavLinkMatch.Prefix">
                <span aria-hidden="true">&#127813;</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link nav-icon" href="journal" title="Journal" Match="NavLinkMatch.Prefix">
                <span aria-hidden="true">&#128214;</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link nav-icon" href="tickets" title="Tickets" Match="NavLinkMatch.Prefix">
                <span aria-hidden="true">&#127915;</span>
            </NavLink>
        </div>
        <div class="nav-item nav-item-settings">
            <NavLink class="nav-link nav-icon" href="settings" title="Parametres" Match="NavLinkMatch.Prefix">
                <span aria-hidden="true">&#9881;</span>
            </NavLink>
        </div>
        <div class="nav-item nav-item-logout">
            <button class="nav-link nav-icon btn-logout" title="Deconnexion" @onclick="LogoutAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </button>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task LogoutAsync()
    {
        await AuthService.RemoveTokenAsync();
        AuthStateProvider.NotifyAuthenticationStateChanged();
        Nav.NavigateTo("/", forceLoad: false);
    }
}
