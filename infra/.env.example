# Kairudev - Variables d'environnement Azure (exemple)
# Copiez ce fichier en .env et remplissez les valeurs réelles
# ⚠️ NE JAMAIS COMMITER .env DANS GIT

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=1234567890abcdef1234567890abcdef12345678

# JWT Secret Key (32+ bytes en base64, généré automatiquement si vide)
# Pour générer : [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JWT_SECRET_KEY=your-base64-encoded-secret-key-here

# Azure SQL Admin Password (complexité requise : maj, min, chiffre, symbole)
SQL_ADMIN_PASSWORD=YourStrongP@ssw0rd123!
